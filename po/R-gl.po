msgid ""
"bootnet crashed with the following error message:\n"
"%s"
msgstr ""
"bootnet rachou coa seguinte mensaxe de fallo:\n"
"%s"

msgid ""
"Please drag all variables to a particular type under \"Analysis options\"."
msgstr ""
"Por favor, arrastra todas as variables a un tipo concreto nas \"Opcións de "
"análise\"."

msgid ""
"Coefficient could not be standardized because the variance is too small."
msgstr ""
"O coeficiente non se puido tipificar porque a varianza é pequena de máis."

msgid "Please supply a name for both the x and y-coordinates of the layout."
msgstr ""
"Por favor, proporciona o nome para as coordenadas tanto x como y do deseño."

msgid "Some variables did not contain char (%s)"
msgstr "Algunhas variables non contiñan char (%s)"

msgid "Some variables were not matched in the column names of the dataset."
msgstr ""
"Algunhas variables non coincidiron cos nomes de columnas do conxunto de "
"datos."

msgid ""
"Supplied data for layout was not understood and instead a circle layout was "
"used."
msgstr ""
"Os datos proporcionados para o deseño non se entenderon, e utilizouse un "
"deseño circular en troques."

msgid ""
"Data supplied in %1$s AND %2$s could not be used to determine node locations."
msgstr ""
"Os datos subministrados en %1$s E %2$s non se poden utilizar para determinar "
"as posicións dos nodos."

msgid "Data supplied in %s could not be used to determine node locations."
msgstr ""
"Os datos subministrados en %s non se poden utilizar para determinar as "
"posicións dos nodos."

msgid ""
"%1$s %2$s Data should only contain numeric:\n"
"                 -start with the column name of the variable.\n"
"                 -contain an '=' to distinguish between column name and "
"coordinate."
msgstr ""
"%1$s %2$s Os datos deben ser só números:\n"
"                 - Comezar co nome de columna da variable.\n"
"                 - Conter un '=' para distinguir entre o nome de columna e a "
"coordenada."

msgid ""
"bootnet crashed with the following error message:\n"
"%s. <ul><li>Please check if there are variables in the network with little "
"variance or few distinct observations.</li></ul>"
msgstr ""
"bootnet rachou coa seguinte mensaxe de fallo:\n"
"%s. <ul><li>Por favor, comproba se hai variables na rede con varianza "
"pequena ou con poucas observacións distintas.</li></ul>"

