msgid ""
"bootnet crashed with the following error message:\n"
"%s"
msgstr ""
"bootnet se quebró con el siguiente mensaje de fallo:\n"
"%s"

msgid ""
"Please drag all variables to a particular type under \"Analysis options\"."
msgstr ""
"Por favor, arrastra todas las variables a un tipo concreto en las \"Opciones "
"de análisis\"."

msgid ""
"Coefficient could not be standardized because the variance is too small."
msgstr ""
"El coeficiente no se pudo tipificar porque la varianza es demasiado pequeña."

msgid "Please supply a name for both the x and y-coordinates of the layout."
msgstr ""
"Por favor, indica el nombre para las coordenadas tanto x como y del diseño."

msgid "Some variables did not contain char (%s)"
msgstr "Algunas variables no contenían char (%s)"

msgid "Some variables were not matched in the column names of the dataset."
msgstr ""
"Algunas variables no coincidieron con los nombres de columnas del conjunto "
"de datos."

msgid ""
"Supplied data for layout was not understood and instead a circle layout was "
"used."
msgstr ""
"Los datos suministrados para el diseño no se entendieron, y se usó en su "
"lugar un diseño circular."

msgid ""
"Data supplied in %1$s AND %2$s could not be used to determine node locations."
msgstr ""
"Los datos suministrados en %1$s Y %2$s no se pueden utilizar para determinar "
"las posiciones de los nodos."

msgid "Data supplied in %s could not be used to determine node locations."
msgstr ""
"Los datos suministrados en %s no se pueden utilizar para determinar las "
"posiciones de los nodos."

msgid ""
"%1$s %2$s Data should only contain numeric:\n"
"                 -start with the column name of the variable.\n"
"                 -contain an '=' to distinguish between column name and "
"coordinate."
msgstr ""
"%1$s %2$s Los datos deben ser solo números:\n"
"                 - Empezar con el nombre de columna de la variable.\n"
"                 - Contener un '=' para distinguir entre el nombre de "
"columna y la coordenada."

msgid ""
"bootnet crashed with the following error message:\n"
"%s. <ul><li>Please check if there are variables in the network with little "
"variance or few distinct observations.</li></ul>"
msgstr ""
"bootnet se quebró con el siguiente mensaje de fallo:\n"
"%s. <ul><li>Por favor, comprueba si hay variables en la red con varianza "
"pequeña o con pocas observaciones distintas.</li></ul>"

